rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function email() {
      return request.auth.token.email;
    }

    function isAdmin() {
      return signedIn() && email() in [
        'alekcaballeromusic@gmail.com',
        'catalina.medina.leal@gmail.com',
        'adminmusicala@gmail.com'
      ];
    }

    function isTeam() {
      return isAdmin();
    }

    function validPublicApplication() {
      return request.resource.data.keys().hasOnly([
        'nombre',
        'submissionId',
        'documento',
        'fechaNacimiento',
        'direccion',
        'email',
        'celular',
        'telefonoFijo',
        'localidad',
        'transporte',
        'clases',
        'instrumento',
        'otraArea1',
        'estilos',
        'otraArea2',
        'enfasis',
        'otraArea3',
        'areaPrincipal',
        'areas',
        'subareas',
        'subareasTexto',
        'modalidades',
        'modalidadesTexto',
        'disponibilidadTexto',
        'disponibilidad',
        'hvUrl',
        'hvStoragePath',
        'hvFileName',
        'hvContentType',
        'hvSize',
        'portafolioUrl',
        'googleMaps',
        'comentarios',
        'resena',
        'consentimiento',
        'customAnswers',
        'estado',
        'source',
        'searchText',
        'createdAt'
      ])
      && request.resource.data.nombre is string
      && request.resource.data.nombre.size() >= 3
      && request.resource.data.nombre.size() <= 120
      && request.resource.data.email is string
      && request.resource.data.email.size() >= 5
      && request.resource.data.email.size() <= 120
      && request.resource.data.celular is string
      && request.resource.data.celular.size() >= 7
      && request.resource.data.celular.size() <= 20
      && request.resource.data.hvSize is int
      && request.resource.data.hvSize > 0
      && request.resource.data.hvSize <= 10 * 1024 * 1024
      && request.resource.data.areaPrincipal is string
      && request.resource.data.areaPrincipal in ['Música', 'Danza', 'Artes plásticas', 'Teatro', 'Cheerleading', 'Otra']
      && request.resource.data.consentimiento == true
      && request.resource.data.estado == 'Nueva'
      && request.resource.data.source == 'formulario_publico';
    }

    match /docentes/{docenteId} {
      allow read: if isTeam();
      allow create, update, delete: if isAdmin();
    }

    match /postulaciones/{postulacionId} {
      allow create: if validPublicApplication();
      allow read: if isTeam();
      allow update, delete: if isAdmin();
    }

    match /necesidades/{necesidadId} {
      allow read: if isTeam();
      allow create, update, delete: if isAdmin();
    }

    match /config/{configId} {
      allow read: if configId == 'formulario' || isTeam();
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
